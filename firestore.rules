rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.role == 'admin';
    }

    function isPremium() {
      return isAuthenticated() &&
        (request.auth.token.role == 'premium' ||
         request.auth.token.role == 'admin'   ||
         request.auth.token.plan  == 'pro'    ||
         request.auth.token.plan  == 'vip');
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen && val.size() > 0;
    }

    function isValidEmail(val) {
      return val is string && val.matches('.*@.*\\..*');
    }

    function notChangingId() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'email']);
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && isValidString(request.resource.data.displayName, 80)
        && isValidEmail(request.resource.data.email)
        && request.resource.data.role == 'free'
        && request.resource.data.plan == 'free';
      allow update: if (isOwner(uid) && notChangingId()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Signals ───────────────────────────────────────────────
    match /signals/{signalId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Strategies ────────────────────────────────────────────
    match /strategies/{strategyId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Market cache (OHLCV) ──────────────────────────────────
    match /market_cache/{pair} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();

      match /candles/{candleId} {
        allow read:  if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // ── Subscriptions ─────────────────────────────────────────
    // Owner can read their own; write is server-only (admin SDK)
    match /subscriptions/{subId} {
      allow read:  if isAuthenticated() && resource.data.uid == request.auth.uid || isAdmin();
      allow write: if isAdmin();
    }

    // ── Payment intents (write = server only) ─────────────────
    match /paymentIntents/{docId} {
      allow read:  if isAuthenticated() && resource.data.uid == request.auth.uid || isAdmin();
      allow write: if isAdmin();
    }

    // ── Payme transactions (server only) ──────────────────────
    match /paymeTransactions/{docId} {
      allow read, write: if isAdmin();
    }

    // ── AI Prompts ────────────────────────────────────────────
    match /prompts/{promptId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow write:  if isAdmin();
    }

    // ── Plans (public read) ───────────────────────────────────
    match /plans/{planId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Price change logs (admin only) ────────────────────────
    match /priceChangeLogs/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Promo codes (admin write, auth read) ──────────────────
    match /promoCodes/{docId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Announcements (public read) ───────────────────────────
    match /announcements/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── FAQ (public read) ─────────────────────────────────────
    match /faq/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Education lessons ─────────────────────────────────────
    match /lessons/{lessonId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── AI instructions ───────────────────────────────────────
    match /aiInstructions/{docId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Signal templates ──────────────────────────────────────
    match /signalTemplates/{docId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Reports ───────────────────────────────────────────────
    match /reports/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Refunds ───────────────────────────────────────────────
    match /refunds/{docId} {
      allow read:  if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
      allow write: if isAdmin();
    }

    // ── System alerts ─────────────────────────────────────────
    match /systemAlerts/{docId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Default: deny all ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

      allow delete: if isAdmin();
    }

    // ── Signals ───────────────────────────────────────────────
    match /signals/{signalId} {
      // Free users: can only read active signals for limited pairs
      allow read: if isAuthenticated();
      // Only server-side Cloud Functions (admin SDK) can write signals
      allow write: if isAdmin();
    }

    // ── Strategies ────────────────────────────────────────────
    match /strategies/{strategyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Market cache (OHLCV) ──────────────────────────────────
    match /market_cache/{pair} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /candles/{candleId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // ── Subscriptions ─────────────────────────────────────────
    match /subscriptions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── AI Prompts ────────────────────────────────────────────
    match /prompts/{promptId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated() &&
        resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow write: if isAdmin();
    }

    // ── Plans (public read) ───────────────────────────────────
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Default: deny all ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
